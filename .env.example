# Image Studio local settings.
# Copy this file to .env and fill in your own values.

# API key for your image provider or relay endpoint.
IMAGE_STUDIO_API_KEY=

# Base URL of the image API (OpenAI-compatible or a relay endpoint).
# Examples: https://api.openai.com  |  https://openrouter.ai/api  |  your own relay
IMAGE_STUDIO_API_BASE=

# Leave empty to store data under ./data
IMAGE_STUDIO_DATA_DIR=
